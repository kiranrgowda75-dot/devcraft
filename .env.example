# Copy this file to `.env` in the project root and fill in real values
# before running `docker compose up`. Never commit the real `.env`.

# --- Database ---
POSTGRES_DB=projectshop
POSTGRES_USER=projectshop
POSTGRES_PASSWORD=change-me-to-a-strong-password

# --- Backend security ---
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-characters

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# --- CORS ---
# Public URL of the deployed frontend (comma-separate multiple origins)
FRONTEND_URL=http://localhost:3000

# --- ImageKit ---
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key_here
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id_here
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key_here
